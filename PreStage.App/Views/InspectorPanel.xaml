<UserControl x:Class="PreStage.App.Views.InspectorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:PreStage.Core.Models;assembly=PreStage.Core"
             xmlns:conv="clr-namespace:PreStage.App.Converters"
             xmlns:controls="clr-namespace:PreStage.App.Controls"
             Background="{StaticResource PanelBackground}">
    <UserControl.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibility"/>
        <conv:FileSizeConverter x:Key="FileSize"/>
        <conv:MediaTypeDisplayConverter x:Key="MediaTypeDisplay"/>
        <conv:EnumEqualityConverter x:Key="EnumEquality"/>
    </UserControl.Resources>

    <Border Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
        <Grid>
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <StackPanel Margin="14,12" Visibility="{Binding SelectedItem, Converter={StaticResource NullToVisibility}}">
                        <TextBlock Style="{StaticResource SidebarSectionHeader}" Text="{Binding Text[Info]}" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding SelectedItem.Filename}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ForegroundPrimary}" TextWrapping="Wrap" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding SelectedItem.Url}" FontSize="9" Foreground="{StaticResource ForegroundSecondary}" TextTrimming="CharacterEllipsis" ToolTip="{Binding SelectedItem.Url}" Margin="0,0,0,6"/>
                        <TextBlock FontSize="10" Foreground="{StaticResource ForegroundSecondary}" Margin="0,0,0,8">
                            <Run Text="{Binding SelectedItem.FileSize, Converter={StaticResource FileSize}}"/>
                            <Run Text=" · "/>
                            <Run Text="{Binding SelectedItem.FileExtension, Converter={StaticResource MediaTypeDisplay}}"/>
                            <Run Text=" · "/>
                            <Run Text="{Binding SelectedItem.MediaType}"/>
                        </TextBlock>

                        <Separator Style="{StaticResource DarkSeparator}" Margin="0,2,0,10"/>

                        <TextBlock Style="{StaticResource SidebarSectionHeader}" Text="{Binding Text[Review]}" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding Text[Rating]}" FontSize="10" Foreground="{StaticResource ForegroundSecondary}" Margin="0,0,0,2"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Button FontSize="13" ToolTip="Rate 1 / click current rating to clear" Command="{Binding SetRatingCommand}" CommandParameter="1">
                                <Button.Style><Style TargetType="Button" BasedOn="{StaticResource IconButton}"><Setter Property="Content" Value="☆"/><Style.Triggers><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="1"><Setter Property="Content" Value="★"/></DataTrigger><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="2"><Setter Property="Content" Value="★"/></DataTrigger><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="3"><Setter Property="Content" Value="★"/></DataTrigger><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="4"><Setter Property="Content" Value="★"/></DataTrigger><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="5"><Setter Property="Content" Value="★"/></DataTrigger></Style.Triggers></Style></Button.Style>
                            </Button>
                            <Button FontSize="13" ToolTip="Rate 2 / click current rating to clear" Command="{Binding SetRatingCommand}" CommandParameter="2">
                                <Button.Style><Style TargetType="Button" BasedOn="{StaticResource IconButton}"><Setter Property="Content" Value="☆"/><Style.Triggers><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="2"><Setter Property="Content" Value="★"/></DataTrigger><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="3"><Setter Property="Content" Value="★"/></DataTrigger><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="4"><Setter Property="Content" Value="★"/></DataTrigger><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="5"><Setter Property="Content" Value="★"/></DataTrigger></Style.Triggers></Style></Button.Style>
                            </Button>
                            <Button FontSize="13" ToolTip="Rate 3 / click current rating to clear" Command="{Binding SetRatingCommand}" CommandParameter="3">
                                <Button.Style><Style TargetType="Button" BasedOn="{StaticResource IconButton}"><Setter Property="Content" Value="☆"/><Style.Triggers><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="3"><Setter Property="Content" Value="★"/></DataTrigger><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="4"><Setter Property="Content" Value="★"/></DataTrigger><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="5"><Setter Property="Content" Value="★"/></DataTrigger></Style.Triggers></Style></Button.Style>
                            </Button>
                            <Button FontSize="13" ToolTip="Rate 4 / click current rating to clear" Command="{Binding SetRatingCommand}" CommandParameter="4">
                                <Button.Style><Style TargetType="Button" BasedOn="{StaticResource IconButton}"><Setter Property="Content" Value="☆"/><Style.Triggers><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="4"><Setter Property="Content" Value="★"/></DataTrigger><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="5"><Setter Property="Content" Value="★"/></DataTrigger></Style.Triggers></Style></Button.Style>
                            </Button>
                            <Button FontSize="13" ToolTip="Rate 5 / click current rating to clear" Command="{Binding SetRatingCommand}" CommandParameter="5">
                                <Button.Style><Style TargetType="Button" BasedOn="{StaticResource IconButton}"><Setter Property="Content" Value="☆"/><Style.Triggers><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="5"><Setter Property="Content" Value="★"/></DataTrigger></Style.Triggers></Style></Button.Style>
                            </Button>
                            <Button Style="{StaticResource ToolbarButton}" Content="Ø" Width="26" Height="24" FontSize="11" Margin="4,0,0,0" ToolTip="{Binding Text[Clear rating]}" Command="{Binding SetRatingCommand}" CommandParameter="0"/>
                        </StackPanel>

                        <TextBlock Text="{Binding Text[Pick State]}" FontSize="10" Foreground="{StaticResource ForegroundSecondary}" Margin="0,2,0,2"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Style="{StaticResource ToolbarButton}" FontSize="10" Content="{Binding Text[Unmarked]}" Width="70" Command="{Binding SetPickStateCommand}" CommandParameter="Unmarked"/>
                            <Button Style="{StaticResource ToolbarButton}" FontSize="10" Content="{Binding Text[Pick]}" Width="48" Foreground="{StaticResource SuccessBrush}" Command="{Binding SetPickStateCommand}" CommandParameter="Pick"/>
                            <Button Style="{StaticResource ToolbarButton}" FontSize="10" Content="{Binding Text[Reject]}" Width="56" Foreground="{StaticResource DangerBrush}" Command="{Binding SetPickStateCommand}" CommandParameter="Reject"/>
                        </StackPanel>

                        <TextBlock Text="{Binding Text[Color Label]}" FontSize="10" Foreground="{StaticResource ForegroundSecondary}" Margin="0,2,0,2"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Width="20" Height="20" Margin="0,0,3,0" ToolTip="None" Command="{Binding SetColorLabelCommand}" CommandParameter=""><Button.Template><ControlTemplate TargetType="Button"><Border Background="#252525" CornerRadius="3" BorderBrush="#555" BorderThickness="1"><TextBlock Text="×" FontSize="10" Foreground="#999" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template></Button>
                            <Button Width="20" Height="20" Margin="0,0,3,0" ToolTip="Red" Command="{Binding SetColorLabelCommand}" CommandParameter="Red"><Button.Template><ControlTemplate TargetType="Button"><Border Background="#E53935" CornerRadius="3"/></ControlTemplate></Button.Template></Button>
                            <Button Width="20" Height="20" Margin="0,0,3,0" ToolTip="Yellow" Command="{Binding SetColorLabelCommand}" CommandParameter="Yellow"><Button.Template><ControlTemplate TargetType="Button"><Border Background="#FDD835" CornerRadius="3"/></ControlTemplate></Button.Template></Button>
                            <Button Width="20" Height="20" Margin="0,0,3,0" ToolTip="Green" Command="{Binding SetColorLabelCommand}" CommandParameter="Green"><Button.Template><ControlTemplate TargetType="Button"><Border Background="#43A047" CornerRadius="3"/></ControlTemplate></Button.Template></Button>
                            <Button Width="20" Height="20" Margin="0,0,3,0" ToolTip="Blue" Command="{Binding SetColorLabelCommand}" CommandParameter="Blue"><Button.Template><ControlTemplate TargetType="Button"><Border Background="#1E88E5" CornerRadius="3"/></ControlTemplate></Button.Template></Button>
                            <Button Width="20" Height="20" Margin="0,0,3,0" ToolTip="Purple" Command="{Binding SetColorLabelCommand}" CommandParameter="Purple"><Button.Template><ControlTemplate TargetType="Button"><Border Background="#8E24AA" CornerRadius="3"/></ControlTemplate></Button.Template></Button>
                        </StackPanel>

                        <StackPanel Margin="0,2,0,10" Visibility="{Binding HistogramPlacement, Converter={StaticResource EnumEquality}, ConverterParameter=Inspector}">
                            <DockPanel Margin="0,0,0,5">
                                <TextBlock Style="{StaticResource SidebarSectionHeader}" Text="{Binding Text[Histogram]}" Margin="0"/>
                                <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}" Content="↗" Width="22" Height="18" ToolTip="{Binding Text[Move to Floating]}" Command="{Binding SetHistogramPlacementCommand}" CommandParameter="Floating"/>
                            </DockPanel>
                            <Border Height="128" Style="{StaticResource ScopePanelBorder}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <controls:HistogramView Data="{Binding HistogramChannel}" DisplayMode="{Binding HistogramMode}"/>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5,3">
                                        <Button Style="{StaticResource ScopeChipButton}" Content="RGB+L" Command="{Binding SetHistogramModeCommand}" CommandParameter="RgbAndLuminance"/>
                                        <Button Style="{StaticResource ScopeChipButton}" Content="RGB" Command="{Binding SetHistogramModeCommand}" CommandParameter="Rgb"/>
                                        <Button Style="{StaticResource ScopeChipButton}" Content="LUM" Command="{Binding SetHistogramModeCommand}" CommandParameter="Luminance"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="0,2,0,10" Visibility="{Binding WaveformPlacement, Converter={StaticResource EnumEquality}, ConverterParameter=Inspector}">
                            <DockPanel Margin="0,0,0,5">
                                <TextBlock Style="{StaticResource SidebarSectionHeader}" Text="{Binding Text[Waveform]}" Margin="0"/>
                                <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}" Content="↗" Width="22" Height="18" ToolTip="{Binding Text[Move to Floating]}" Command="{Binding SetWaveformPlacementCommand}" CommandParameter="Floating"/>
                            </DockPanel>
                            <Border Height="142" Style="{StaticResource ScopePanelBorder}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <controls:WaveformView Waveform="{Binding WaveformData}" MaxValue="{Binding WaveformMaxValue}" ChannelMode="{Binding WaveformChannelMode}"/>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5,3">
                                        <Button Style="{StaticResource ScopeChipButton}" Content="LUM" Command="{Binding SetWaveformChannelModeCommand}" CommandParameter="Luminance"/>
                                        <Button Style="{StaticResource ScopeChipButton}" Content="RGB" Command="{Binding SetWaveformChannelModeCommand}" CommandParameter="Rgb"/>
                                        <Button Style="{StaticResource ScopeChipButton}" Content="X/Y" Command="{Binding ToggleWaveformDirectionCommand}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <Separator Style="{StaticResource DarkSeparator}" Margin="0,2,0,10"/>

                        <TextBlock Style="{StaticResource SidebarSectionHeader}" Text="{Binding Text[Metadata]}" Margin="0,0,0,6"/>
                        <Grid Style="{StaticResource MetadataGrid}">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="92"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Text[Created]}" Style="{StaticResource MetadataLabel}"/><TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedItem.CreatedDate, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Style="{StaticResource MetadataValue}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Text[Captured]}" Style="{StaticResource MetadataLabel}"/><TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedItem.CaptureDate, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Style="{StaticResource MetadataValue}"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding Text[Modified]}" Style="{StaticResource MetadataLabel}"/><TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedItem.ModifiedDate, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Style="{StaticResource MetadataValue}"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Last Opened" Style="{StaticResource MetadataLabel}"/><TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedItem.LastOpenedDate, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Style="{StaticResource MetadataValue}"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding Text[Dimensions]}" Style="{StaticResource MetadataLabel}"/><TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource MetadataValue}"><Run Text="{Binding SelectedItem.PixelWidth}"/><Run Text=" × "/><Run Text="{Binding SelectedItem.PixelHeight}"/></TextBlock>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="{Binding Text[Display]}" Style="{StaticResource MetadataLabel}"/><TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource MetadataValue}"><Run Text="{Binding SelectedItem.DisplayPixelWidth}"/><Run Text=" × "/><Run Text="{Binding SelectedItem.DisplayPixelHeight}"/></TextBlock>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="{Binding Text[Color Space]}" Style="{StaticResource MetadataLabel}"/><TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedItem.ColorSpaceName}" Style="{StaticResource MetadataValue}"/>
                            <TextBlock Grid.Row="7" Grid.Column="0" Text="{Binding Text[Profile]}" Style="{StaticResource MetadataLabel}"/><TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding SelectedItem.ColorProfileName}" Style="{StaticResource MetadataValue}"/>
                            <TextBlock Grid.Row="8" Grid.Column="0" Text="{Binding Text[Camera]}" Style="{StaticResource MetadataLabel}"/><TextBlock Grid.Row="8" Grid.Column="1" Style="{StaticResource MetadataValue}"><Run Text="{Binding SelectedItem.CameraMake}"/><Run Text=" "/><Run Text="{Binding SelectedItem.CameraModel}"/></TextBlock>
                            <TextBlock Grid.Row="9" Grid.Column="0" Text="{Binding Text[Lens]}" Style="{StaticResource MetadataLabel}"/><TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding SelectedItem.LensModel}" Style="{StaticResource MetadataValue}"/>
                            <TextBlock Grid.Row="10" Grid.Column="0" Text="{Binding Text[Exposure]}" Style="{StaticResource MetadataLabel}"/><TextBlock Grid.Row="10" Grid.Column="1" Style="{StaticResource MetadataValue}"><Run Text="ISO "/><Run Text="{Binding SelectedItem.Iso}"/><Run Text="  f/"/><Run Text="{Binding SelectedItem.Aperture}"/><Run Text="  "/><Run Text="{Binding SelectedItem.ShutterSpeed}"/></TextBlock>
                            <TextBlock Grid.Row="11" Grid.Column="0" Text="{Binding Text[Focal]}" Style="{StaticResource MetadataLabel}"/><TextBlock Grid.Row="11" Grid.Column="1" Text="{Binding SelectedItem.FocalLength, StringFormat='{}{0} mm'}" Style="{StaticResource MetadataValue}"/>
                            <TextBlock Grid.Row="12" Grid.Column="0" Text="{Binding Text[Pair]}" Style="{StaticResource MetadataLabel}"/><TextBlock Grid.Row="12" Grid.Column="1" Text="{Binding SelectedItem.PairedAssetKey}" Style="{StaticResource MetadataValue}"/>
                            <TextBlock Grid.Row="13" Grid.Column="0" Text="{Binding Text[Copy]}" Style="{StaticResource MetadataLabel}"/><TextBlock Grid.Row="13" Grid.Column="1" Text="{Binding SelectedItem.CopyStatus}" Style="{StaticResource MetadataValue}"/>
                            <TextBlock Grid.Row="14" Grid.Column="0" Text="XMP" Style="{StaticResource MetadataLabel}"/><TextBlock Grid.Row="14" Grid.Column="1" Text="{Binding SelectedItem.XmpStatus}" Style="{StaticResource MetadataValue}"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Margin="16" VerticalAlignment="Center" Visibility="{Binding SelectedItem, Converter={StaticResource NullToVisibility}, ConverterParameter=Invert}">
                        <TextBlock Text="{Binding Text[Inspector]}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource ForegroundPrimary}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Text[SelectMediaHint]}" FontSize="11" Foreground="{StaticResource ForegroundSecondary}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
