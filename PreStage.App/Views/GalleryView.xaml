<UserControl x:Class="PreStage.App.Views.GalleryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PreStage.App.Controls"
             xmlns:vm="clr-namespace:PreStage.ViewModels;assembly=PreStage.ViewModels"
             xmlns:models="clr-namespace:PreStage.Core.Models;assembly=PreStage.Core"
             xmlns:conv="clr-namespace:PreStage.App.Converters"
             Background="{StaticResource AppBackground}">
    <UserControl.Resources>
        <conv:FileSizeConverter x:Key="FileSize"/>
        <conv:MediaTypeDisplayConverter x:Key="MediaTypeDisplay"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
        <conv:EnumEqualityConverter x:Key="EnumEquality"/>
        <conv:EqualityConverter x:Key="EqualityConv"/>
        <conv:BoolToScaleConverter x:Key="BoolToScale"/>
        <conv:ThumbnailConverter x:Key="ThumbnailConv"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <controls:GalleryPreviewPanel x:Name="PreviewPanel" Grid.Row="0"
            ImageSource="{Binding PreviewImageSource}"
            ImageAspectRatio="{Binding PreviewAspectRatio}"
            DpiScale="{Binding DpiScale}"
            CropAspectRatio="{Binding CropAspectRatioDouble}"
            CropStyle="{Binding CropStyle}"
            ActiveGuides="{Binding ActiveGuides}"
            GuidesFollowCrop="{Binding GuidesFollowCrop}"
            GuideColor="{Binding GuideColor}"
            GuideOpacity="{Binding GuideOpacity}">
            <controls:GalleryPreviewPanel.LayoutTransform>
                <ScaleTransform ScaleX="{Binding FlippedHorizontally, Converter={StaticResource BoolToScale}}"
                                ScaleY="{Binding FlippedVertically, Converter={StaticResource BoolToScale}}"/>
            </controls:GalleryPreviewPanel.LayoutTransform>
        </controls:GalleryPreviewPanel>

        <Button Grid.Row="0" Style="{StaticResource IconButton}" Width="32" Height="44"
                HorizontalAlignment="Left" VerticalAlignment="Center" Margin="6,0,0,0"
                Content="◀" FontSize="16" ToolTip="Previous (←)"
                Command="{Binding NavigateGalleryCommand}" CommandParameter="Prev"/>
        <Button Grid.Row="0" Style="{StaticResource IconButton}" Width="32" Height="44"
                HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0"
                Content="▶" FontSize="16" ToolTip="Next (→)"
                Command="{Binding NavigateGalleryCommand}" CommandParameter="Next"/>

        <Border x:Name="HistogramPanel" Grid.Row="0" Width="246" Height="138"
                Visibility="{Binding HistogramPlacement, Converter={StaticResource EnumEquality}, ConverterParameter=Floating}"
                HorizontalAlignment="Left" VerticalAlignment="Top" Margin="44,44,0,0"
                Style="{StaticResource ScopePanelBorder}"
                MouseLeftButtonDown="FloatingPanel_DragStart" MouseMove="FloatingPanel_DragMove" MouseLeftButtonUp="FloatingPanel_DragEnd">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="24"/>
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="7,3,5,0">
                    <TextBlock Text="▥ Histogram" Foreground="{StaticResource ForegroundPrimary}" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Style="{StaticResource IconButton}" Content="⇥" Width="20" Height="18" FontSize="10" ToolTip="Move to Inspector" Command="{Binding SetHistogramPlacementCommand}" CommandParameter="Inspector"/>
                        <Button Style="{StaticResource IconButton}" Content="×" Width="20" Height="18" FontSize="10" ToolTip="Hide" Command="{Binding SetHistogramPlacementCommand}" CommandParameter="Hidden"/>
                    </StackPanel>
                </DockPanel>
                <controls:HistogramView Grid.Row="1" Data="{Binding HistogramChannel}" DisplayMode="{Binding HistogramMode}"/>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="7,2">
                    <Button Style="{StaticResource ScopeChipButton}" Content="RGB+L" Command="{Binding SetHistogramModeCommand}" CommandParameter="RgbAndLuminance"/>
                    <Button Style="{StaticResource ScopeChipButton}" Content="RGB" Command="{Binding SetHistogramModeCommand}" CommandParameter="Rgb"/>
                    <Button Style="{StaticResource ScopeChipButton}" Content="LUM" Command="{Binding SetHistogramModeCommand}" CommandParameter="Luminance"/>
                    <Button Style="{StaticResource ScopeChipButton}" Content="R" Command="{Binding SetHistogramModeCommand}" CommandParameter="Red"/>
                    <Button Style="{StaticResource ScopeChipButton}" Content="G" Command="{Binding SetHistogramModeCommand}" CommandParameter="Green"/>
                    <Button Style="{StaticResource ScopeChipButton}" Content="B" Command="{Binding SetHistogramModeCommand}" CommandParameter="Blue"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="WaveformPanel" Grid.Row="0" Width="260" Height="148"
                Visibility="{Binding WaveformPlacement, Converter={StaticResource EnumEquality}, ConverterParameter=Floating}"
                HorizontalAlignment="Left" VerticalAlignment="Top" Margin="44,196,0,0"
                Style="{StaticResource ScopePanelBorder}"
                MouseLeftButtonDown="FloatingPanel_DragStart" MouseMove="FloatingPanel_DragMove" MouseLeftButtonUp="FloatingPanel_DragEnd">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="24"/>
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="7,3,5,0">
                    <TextBlock Text="⌁ Waveform" Foreground="{StaticResource ForegroundPrimary}" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Style="{StaticResource IconButton}" Content="⇥" Width="20" Height="18" FontSize="10" ToolTip="Move to Inspector" Command="{Binding SetWaveformPlacementCommand}" CommandParameter="Inspector"/>
                        <Button Style="{StaticResource IconButton}" Content="×" Width="20" Height="18" FontSize="10" ToolTip="Hide" Command="{Binding SetWaveformPlacementCommand}" CommandParameter="Hidden"/>
                    </StackPanel>
                </DockPanel>
                <controls:WaveformView Grid.Row="1" Waveform="{Binding WaveformData}" MaxValue="{Binding WaveformMaxValue}" ChannelMode="{Binding WaveformChannelMode}"/>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="7,2">
                    <Button Style="{StaticResource ScopeChipButton}" Content="LUM" Command="{Binding SetWaveformChannelModeCommand}" CommandParameter="Luminance"/>
                    <Button Style="{StaticResource ScopeChipButton}" Content="RGB" Command="{Binding SetWaveformChannelModeCommand}" CommandParameter="Rgb"/>
                    <Button Style="{StaticResource ScopeChipButton}" Content="R" Command="{Binding SetWaveformChannelModeCommand}" CommandParameter="Red"/>
                    <Button Style="{StaticResource ScopeChipButton}" Content="G" Command="{Binding SetWaveformChannelModeCommand}" CommandParameter="Green"/>
                    <Button Style="{StaticResource ScopeChipButton}" Content="B" Command="{Binding SetWaveformChannelModeCommand}" CommandParameter="Blue"/>
                    <Button Style="{StaticResource ScopeChipButton}" Content="X/Y" ToolTip="Toggle direction" Command="{Binding ToggleWaveformDirectionCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource ToolbarBackground}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,1" Height="28">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,0,0">
                    <Button Style="{StaticResource IconButton}" Content="▥" ToolTip="Histogram (H)" FontSize="11" Command="{Binding ToggleHistogramCommand}"/>
                    <Button Style="{StaticResource IconButton}" Content="📈" ToolTip="Waveform (W)" FontSize="11" Command="{Binding ToggleWaveformCommand}"/>
                    <Button Style="{StaticResource IconButton}" Content="↔" ToolTip="Waveform Direction" FontSize="11" Command="{Binding ToggleWaveformDirectionCommand}"/>
                    <Separator Style="{StaticResource DarkSeparator}" Margin="2,0"/>
                    <Button Style="{StaticResource IconButton}" Content="⊞" ToolTip="Rule of Thirds" Command="{Binding ToggleGuideCommand}" CommandParameter="Thirds"/>
                    <Button Style="{StaticResource IconButton}" Content="⊕" ToolTip="Center" Command="{Binding ToggleGuideCommand}" CommandParameter="Center"/>
                    <Button Style="{StaticResource IconButton}" Content="╳" ToolTip="Diagonals" Command="{Binding ToggleGuideCommand}" CommandParameter="Diagonals"/>
                    <Button Style="{StaticResource IconButton}" Content="Φ" ToolTip="Golden Ratio" Command="{Binding ToggleGuideCommand}" CommandParameter="GoldenRatio"/>
                    <Button Style="{StaticResource IconButton}" Content="⚙" ToolTip="Guide Options">
                        <Button.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="Guides follow image" Command="{Binding SetGuidesFollowCropCommand}" CommandParameter="False"/>
                                <MenuItem Header="Guides follow crop" Command="{Binding SetGuidesFollowCropCommand}" CommandParameter="True"/>
                                <Separator/>
                                <MenuItem Header="Gray" Command="{Binding SetGuideColorCommand}" CommandParameter="Gray"/>
                                <MenuItem Header="White" Command="{Binding SetGuideColorCommand}" CommandParameter="White"/>
                                <MenuItem Header="Black" Command="{Binding SetGuideColorCommand}" CommandParameter="Black"/>
                                <MenuItem Header="Accent" Command="{Binding SetGuideColorCommand}" CommandParameter="Accent"/>
                                <Separator/>
                                <MenuItem Header="Opacity 30%" Command="{Binding SetGuideOpacityCommand}" CommandParameter="0.3"/>
                                <MenuItem Header="Opacity 50%" Command="{Binding SetGuideOpacityCommand}" CommandParameter="0.5"/>
                                <MenuItem Header="Opacity 80%" Command="{Binding SetGuideOpacityCommand}" CommandParameter="0.8"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Separator Style="{StaticResource DarkSeparator}" Margin="2,0"/>
                    <Button Style="{StaticResource IconButton}" Content="⬚" ToolTip="Hide Crop" Command="{Binding SetCropRatioCommand}" CommandParameter="Hidden"/>
                    <Button Style="{StaticResource IconButton}" Content="1:1" ToolTip="1:1" FontSize="9" Command="{Binding SetCropRatioCommand}" CommandParameter="1:1"/>
                    <Button Style="{StaticResource IconButton}" Content="4:3" ToolTip="4:3" FontSize="9" Command="{Binding SetCropRatioCommand}" CommandParameter="4:3"/>
                    <Button Style="{StaticResource IconButton}" Content="3:2" ToolTip="3:2" FontSize="9" Command="{Binding SetCropRatioCommand}" CommandParameter="3:2"/>
                    <Button Style="{StaticResource IconButton}" Content="16:9" ToolTip="16:9" FontSize="9" Command="{Binding SetCropRatioCommand}" CommandParameter="16:9"/>
                    <Button Style="{StaticResource IconButton}" Content="5:4" ToolTip="5:4" FontSize="9" Command="{Binding SetCropRatioCommand}" CommandParameter="5:4"/>
                    <Button Style="{StaticResource IconButton}" Content="9:16" ToolTip="9:16" FontSize="9" Command="{Binding SetCropRatioCommand}" CommandParameter="9:16"/>
                    <Button Style="{StaticResource IconButton}" Content="M/F" ToolTip="Toggle Mask/Frame" FontSize="9" Command="{Binding ToggleCropStyleCommand}"/>
                    <Button Style="{StaticResource IconButton}" Content="↕" ToolTip="Crop Orientation">
                        <Button.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="Automatic" Command="{Binding SetCropOrientationCommand}" CommandParameter="Automatic"/>
                                <MenuItem Header="Landscape" Command="{Binding SetCropOrientationCommand}" CommandParameter="Landscape"/>
                                <MenuItem Header="Portrait" Command="{Binding SetCropOrientationCommand}" CommandParameter="Portrait"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Style="{StaticResource IconButton}" Content="＋" ToolTip="Add Custom 16:9 Crop" FontSize="10" Command="{Binding AddCustomCropRatioCommand}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,6,0">
                    <Button Style="{StaticResource IconButton}" Content="↺" ToolTip="Rotate Left" FontSize="11" Command="{Binding RotateLeftCommand}"/>
                    <Button Style="{StaticResource IconButton}" Content="↻" ToolTip="Rotate Right" FontSize="11" Command="{Binding RotateRightCommand}"/>
                    <Button Style="{StaticResource IconButton}" Content="⇔" ToolTip="Flip Horizontal" FontSize="11" Command="{Binding FlipHorizontalCommand}"/>
                    <Button Style="{StaticResource IconButton}" Content="⇕" ToolTip="Flip Vertical" FontSize="11" Command="{Binding FlipVerticalCommand}"/>
                    <Separator Style="{StaticResource DarkSeparator}" Margin="2,0"/>
                    <Button Style="{StaticResource IconButton}" Content="🗗" ToolTip="Toggle Filmstrip (F)" Command="{Binding ToggleFilmstripCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Height="88" Visibility="{Binding IsFilmstripCollapsed, Converter={StaticResource InverseBool}}"
                Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                          PreviewMouseWheel="Filmstrip_MouseWheel">
                <ListBox ItemsSource="{Binding FilmstripItems}" SelectedValue="{Binding SelectedItem}" SelectedValuePath="Item"
                     Style="{StaticResource SidebarList}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Disabled"
                     BorderThickness="0" Background="Transparent">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" IsItemsHost="True"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="vm:FilmstripItem">
                        <Border Width="{Binding Width}" Height="78" Margin="2" Background="{StaticResource GridItemBackground}" CornerRadius="2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Margin="3" Background="#1A1A1A" CornerRadius="1">
                                    <Grid>
                                        <TextBlock Text="{Binding Item.FileExtension, Converter={StaticResource MediaTypeDisplay}}" Foreground="{StaticResource ForegroundSecondary}" FontSize="8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Image Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality">
                                            <Image.Source>
                                                <MultiBinding Converter="{StaticResource ThumbnailConv}">
                                                    <Binding Path="Item.Url"/>
                                                    <Binding RelativeSource="{RelativeSource AncestorType=UserControl}" Path="DataContext"/>
                                                    <Binding RelativeSource="{RelativeSource AncestorType=UserControl}" Path="DataContext.ThumbnailVersion"/>
                                                </MultiBinding>
                                            </Image.Source>
                                        </Image>
                                    </Grid>
                                </Border>
                                <TextBlock Grid.Row="1" Text="{Binding Item.Filename}" Foreground="{StaticResource ForegroundSecondary}" FontSize="8" Margin="3,0,3,2" TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
