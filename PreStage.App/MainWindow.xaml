<Window x:Class="PreStage.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PreStage.ViewModels;assembly=PreStage.ViewModels"
        xmlns:models="clr-namespace:PreStage.Core.Models;assembly=PreStage.Core"
        xmlns:services="clr-namespace:PreStage.Core.Services;assembly=PreStage.Core"
        xmlns:conv="clr-namespace:PreStage.App.Converters"
        xmlns:views="clr-namespace:PreStage.App.Views"
        xmlns:controls="clr-namespace:PreStage.App.Controls"
        mc:Ignorable="d"
        Style="{StaticResource MainWindowStyle}"
        Title="PreStage" Height="720" Width="1280"
        MinHeight="480" MinWidth="960">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisibility"/>
        <conv:ViewModeConverter x:Key="ViewModeConv"/>
        <conv:FileSizeConverter x:Key="FileSize"/>
        <conv:MediaTypeDisplayConverter x:Key="MediaTypeDisplay"/>
        <conv:EnumEqualityConverter x:Key="EnumEquality"/>
        <conv:EqualityConverter x:Key="EqualityConv"/>
        <conv:ThumbnailConverter x:Key="ThumbnailConv"/>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource ToolbarBackground}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Height="36" Margin="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button ToolTip="Copy selected files to target" Command="{Binding StartCopyCommand}" Height="30" FontSize="12" Padding="8,4">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Content" Value="📋"/>
                                <Setter Property="Width" Value="32"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource AccentHover}"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding ToolbarDisplayMode}" Value="TextOnly">
                                        <Setter Property="Content" Value="Copy"/>
                                        <Setter Property="Width" Value="Auto"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ToolbarDisplayMode}" Value="Both">
                                        <Setter Property="Content" Value="📋 Copy"/>
                                        <Setter Property="Width" Value="Auto"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button ToolTip="Copy Settings" Command="{Binding ToggleCopySettingsCommand}" Height="30" FontSize="12" Padding="8,4">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
                                <Setter Property="Content" Value="⚙"/>
                                <Setter Property="Width" Value="32"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ToolbarDisplayMode}" Value="TextOnly">
                                        <Setter Property="Content" Value="Settings"/>
                                        <Setter Property="Width" Value="Auto"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ToolbarDisplayMode}" Value="Both">
                                        <Setter Property="Content" Value="⚙ Settings"/>
                                        <Setter Property="Width" Value="Auto"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button ToolTip="Share/Export" Command="{Binding ShareItemsCommand}" Height="30" FontSize="12" Padding="8,4">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
                                <Setter Property="Content" Value="↗"/>
                                <Setter Property="Width" Value="32"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ToolbarDisplayMode}" Value="TextOnly">
                                        <Setter Property="Content" Value="Export"/>
                                        <Setter Property="Width" Value="Auto"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ToolbarDisplayMode}" Value="Both">
                                        <Setter Property="Content" Value="↗ Export"/>
                                        <Setter Property="Width" Value="Auto"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <Button x:Name="MoreButton" Grid.Column="1" Style="{StaticResource IconButton}" Content="…" ToolTip="More" Width="32" Height="30" FontSize="14" VerticalAlignment="Center" Margin="4,0,0,0" Click="MoreButton_Click">
                    <Button.ContextMenu>
                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="Open" Command="{Binding OpenItemsCommand}"/>
                            <MenuItem Header="Reveal in Explorer" Command="{Binding RevealInExplorerCommand}"/>
                            <Separator/>
                            <MenuItem Header="Copy Log" Command="{Binding ToggleCopyLogCommand}"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <TextBox Grid.Column="2" Style="{StaticResource SearchTextBox}" Width="180" Margin="12,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Right" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" MinWidth="200" MaxWidth="400"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource ToolbarBackground}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,8,0,8">

                        <TextBlock Style="{StaticResource SidebarSectionHeader}" Text="CAMERA CARD" Margin="12,0,0,4"/>
                        <ItemsControl ItemsSource="{Binding DetectedCards}" Margin="12,4,12,6">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type services:CameraCardInfo}">
                                    <Border Background="{StaticResource GridItemBackground}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,0,0,4">
                                        <StackPanel>
                                            <TextBlock Text="{Binding DriveLabel}" FontSize="11" Foreground="{StaticResource ForegroundPrimary}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding DcimPath}" FontSize="9" Foreground="{StaticResource ForegroundSecondary}" TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <Button Style="{StaticResource ToolbarButton}" FontSize="10" Content="Open" Width="44"
                                                        Command="{Binding DataContext.OpenCameraCardCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Style="{StaticResource ToolbarButton}" FontSize="10" Content="Eject" Width="44" Margin="4,0,0,0"
                                                        Command="{Binding DataContext.EjectCardCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="On Insert" FontSize="10" Foreground="{StaticResource ForegroundSecondary}" Margin="12,0,0,2"/>
                        <ComboBox Style="{StaticResource DarkComboBox}" Width="160" HorizontalAlignment="Left" Margin="12,0,12,8" SelectedValue="{Binding CameraCardAction}" SelectedValuePath="Tag">
                            <ComboBoxItem Content="Notify Only" Tag="{x:Static models:CameraCardAction.Notify}"/>
                            <ComboBoxItem Content="Off" Tag="{x:Static models:CameraCardAction.Off}"/>
                            <ComboBoxItem Content="Select DCIM" Tag="{x:Static models:CameraCardAction.SelectDcim}"/>
                            <ComboBoxItem Content="Select and Scan" Tag="{x:Static models:CameraCardAction.SelectAndScan}"/>
                        </ComboBox>

                        <TextBlock Style="{StaticResource SidebarSectionHeader}" Text="SOURCE"/>
                        <StackPanel Margin="12,4,12,6">
                            <Button Style="{StaticResource ToolbarButton}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Content="Choose Folder..." Command="{Binding SelectSourceFolderCommand}"/>
                            <TextBlock Text="{Binding SourcePath}" FontSize="10" Foreground="{StaticResource ForegroundSecondary}" TextTrimming="CharacterEllipsis" Margin="0,4,0,0" ToolTip="{Binding SourcePath}"/>
                            <CheckBox Style="{StaticResource DarkCheckBox}" Margin="0,4,0,0" IsChecked="{Binding IncludeSubfolders}" Content="Include subfolders"/>
                            <TreeView ItemsSource="{Binding SourceFolderTree}" Background="Transparent" BorderThickness="0" MaxHeight="160" Margin="0,4,0,0">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="Foreground" Value="{StaticResource ForegroundSecondary}"/>
                                        <Setter Property="FontSize" Value="10"/>
                                        <Setter Property="IsExpanded" Value="False"/>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                        <TextBlock Text="{Binding Name}" Cursor="Hand" Margin="0,1" ToolTip="{Binding FullPath}">
                                            <TextBlock.InputBindings>
                                                <MouseBinding Gesture="LeftClick"
                                                              Command="{Binding DataContext.SelectSourcePathCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding FullPath}"/>
                                            </TextBlock.InputBindings>
                                        </TextBlock>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </StackPanel>

                        <TextBlock Style="{StaticResource SidebarSectionHeader}" Text="TARGET"/>
                        <StackPanel Margin="12,4,12,6">
                            <Button Style="{StaticResource ToolbarButton}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Content="Choose Folder..." Command="{Binding SelectTargetFolderCommand}"/>
                            <TextBlock Text="{Binding TargetPath}" FontSize="10" Foreground="{StaticResource ForegroundSecondary}" TextTrimming="CharacterEllipsis" Margin="0,4,0,0" ToolTip="{Binding TargetPath}"/>
                            <TreeView ItemsSource="{Binding TargetFolderTree}" Background="Transparent" BorderThickness="0" MaxHeight="160" Margin="0,4,0,0">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="Foreground" Value="{StaticResource ForegroundSecondary}"/>
                                        <Setter Property="FontSize" Value="10"/>
                                        <Setter Property="IsExpanded" Value="False"/>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                        <TextBlock Text="{Binding Name}" Cursor="Hand" Margin="0,1" ToolTip="{Binding FullPath}">
                                            <TextBlock.InputBindings>
                                                <MouseBinding Gesture="LeftClick"
                                                              Command="{Binding DataContext.SelectTargetPathCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding FullPath}"/>
                                            </TextBlock.InputBindings>
                                        </TextBlock>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </StackPanel>

                        <StackPanel Margin="12,4,12,6" Visibility="{Binding ShowCopySettings, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Style="{StaticResource SidebarSectionHeader}" Text="COPY" Margin="0,0,0,4"/>
                            <TextBlock Text="Organization" FontSize="10" Foreground="{StaticResource ForegroundSecondary}" Margin="0,0,0,2"/>
                            <ComboBox Style="{StaticResource DarkComboBox}" Width="160" HorizontalAlignment="Left" SelectedIndex="0" SelectedValue="{Binding CopyRule}" SelectedValuePath="Tag">
                                <ComboBoxItem Content="Capture Date" Tag="{x:Static models:CopyOrganizationRule.CaptureDate}"/>
                                <ComboBoxItem Content="Preserve Structure" Tag="{x:Static models:CopyOrganizationRule.PreserveStructure}"/>
                                <ComboBoxItem Content="Camera Model" Tag="{x:Static models:CopyOrganizationRule.CameraModel}"/>
                                <ComboBoxItem Content="Rating" Tag="{x:Static models:CopyOrganizationRule.Rating}"/>
                            </ComboBox>
                            <TextBlock Text="Conflict" FontSize="10" Foreground="{StaticResource ForegroundSecondary}" Margin="0,4,0,2"/>
                            <ComboBox Style="{StaticResource DarkComboBox}" Width="160" HorizontalAlignment="Left" SelectedIndex="0" SelectedValue="{Binding CopyConflictPolicy}" SelectedValuePath="Tag">
                                <ComboBoxItem Content="Auto Rename" Tag="{x:Static models:CopyConflictPolicy.AutoRename}"/>
                                <ComboBoxItem Content="Skip" Tag="{x:Static models:CopyConflictPolicy.SkipExisting}"/>
                                <ComboBoxItem Content="Overwrite" Tag="{x:Static models:CopyConflictPolicy.Overwrite}"/>
                            </ComboBox>
                            <TextBlock Text="Content" FontSize="10" Foreground="{StaticResource ForegroundSecondary}" Margin="0,4,0,2"/>
                            <ComboBox Style="{StaticResource DarkComboBox}" Width="160" HorizontalAlignment="Left" SelectedValue="{Binding CopyContentMode}" SelectedValuePath="Tag">
                                <ComboBoxItem Content="All Supported" Tag="{x:Static models:CopyContentMode.AllSupported}"/>
                                <ComboBoxItem Content="RAW Only" Tag="{x:Static models:CopyContentMode.RawOnly}"/>
                            </ComboBox>
                            <TextBlock Text="Verification" FontSize="10" Foreground="{StaticResource ForegroundSecondary}" Margin="0,4,0,2"/>
                            <ComboBox Style="{StaticResource DarkComboBox}" Width="160" HorizontalAlignment="Left" SelectedValue="{Binding CopyVerificationMode}" SelectedValuePath="Tag">
                                <ComboBoxItem Content="Size Only" Tag="{x:Static models:CopyVerificationMode.SizeOnly}"/>
                                <ComboBoxItem Content="SHA-256 Hash" Tag="{x:Static models:CopyVerificationMode.Sha256}"/>
                            </ComboBox>
                        </StackPanel>

                        <TextBlock Style="{StaticResource SidebarSectionHeader}" Text="FILTER"/>
                        <StackPanel Margin="12,4,12,6">
                            <TextBlock Text="Min Rating" FontSize="10" Foreground="{StaticResource ForegroundSecondary}" Margin="0,0,0,2"/>
                            <ComboBox Style="{StaticResource DarkComboBox}" Width="120" HorizontalAlignment="Left" SelectedIndex="{Binding MinimumRating, Mode=TwoWay}">
                                <ComboBoxItem Content="Any"/>
                                <ComboBoxItem Content="★+"/>
                                <ComboBoxItem Content="★★+"/>
                                <ComboBoxItem Content="★★★+"/>
                                <ComboBoxItem Content="★★★★+"/>
                                <ComboBoxItem Content="★★★★★"/>
                            </ComboBox>
                            <CheckBox Style="{StaticResource DarkCheckBox}" Margin="0,6,0,0" IsChecked="{Binding IsStackExpanded}" Content="Show paired RAW+JPEG"/>
                            <TextBlock Text="Color Label" FontSize="10" Foreground="{StaticResource ForegroundSecondary}" Margin="0,8,0,2"/>
                            <ComboBox Style="{StaticResource DarkComboBox}" Width="140" HorizontalAlignment="Left" SelectedValue="{Binding FilterColorLabel}" SelectedValuePath="Tag">
                                <ComboBoxItem Content="Any" Tag="{x:Null}"/>
                                <ComboBoxItem Content="Red" Tag="{x:Static models:ColorLabel.Red}"/>
                                <ComboBoxItem Content="Yellow" Tag="{x:Static models:ColorLabel.Yellow}"/>
                                <ComboBoxItem Content="Green" Tag="{x:Static models:ColorLabel.Green}"/>
                                <ComboBoxItem Content="Blue" Tag="{x:Static models:ColorLabel.Blue}"/>
                                <ComboBoxItem Content="Purple" Tag="{x:Static models:ColorLabel.Purple}"/>
                            </ComboBox>
                            <TextBlock Text="Pick State" FontSize="10" Foreground="{StaticResource ForegroundSecondary}" Margin="0,4,0,2"/>
                            <ComboBox Style="{StaticResource DarkComboBox}" Width="140" HorizontalAlignment="Left" SelectedValue="{Binding FilterPickState}" SelectedValuePath="Tag">
                                <ComboBoxItem Content="Any" Tag="{x:Null}"/>
                                <ComboBoxItem Content="Picked" Tag="{x:Static models:PickState.Picked}"/>
                                <ComboBoxItem Content="Rejected" Tag="{x:Static models:PickState.Rejected}"/>
                                <ComboBoxItem Content="Unmarked" Tag="{x:Static models:PickState.Unmarked}"/>
                            </ComboBox>
                        </StackPanel>

                        <TextBlock Style="{StaticResource SidebarSectionHeader}" Text="REVIEW"/>
                        <StackPanel Margin="12,4,12,6">
                            <TextBlock Text="Preview Background" FontSize="10" Foreground="{StaticResource ForegroundSecondary}" Margin="0,0,0,2"/>
                            <ComboBox Style="{StaticResource DarkComboBox}" Width="140" HorizontalAlignment="Left" SelectedIndex="0" SelectedValue="{Binding PreviewBg}" SelectedValuePath="Tag">
                                <ComboBoxItem Content="System" Tag="{x:Static models:PreviewBackgroundTone.System}"/>
                                <ComboBoxItem Content="Black" Tag="{x:Static models:PreviewBackgroundTone.Black}"/>
                                <ComboBoxItem Content="White" Tag="{x:Static models:PreviewBackgroundTone.White}"/>
                                <ComboBoxItem Content="Dark Gray" Tag="{x:Static models:PreviewBackgroundTone.DarkGray}"/>
                                <ComboBoxItem Content="Mid Gray" Tag="{x:Static models:PreviewBackgroundTone.MiddleGray}"/>
                                <ComboBoxItem Content="Light Gray" Tag="{x:Static models:PreviewBackgroundTone.LightGray}"/>
                            </ComboBox>
                            <TextBlock Text="Toolbar" FontSize="10" Foreground="{StaticResource ForegroundSecondary}" Margin="0,8,0,2"/>
                            <ComboBox Style="{StaticResource DarkComboBox}" Width="140" HorizontalAlignment="Left" SelectedValue="{Binding ToolbarDisplayMode}" SelectedValuePath="Tag">
                                <ComboBoxItem Content="Icons Only" Tag="{x:Static models:ToolbarDisplayMode.IconOnly}"/>
                                <ComboBoxItem Content="Text Only" Tag="{x:Static models:ToolbarDisplayMode.TextOnly}"/>
                                <ComboBoxItem Content="Icons + Text" Tag="{x:Static models:ToolbarDisplayMode.Both}"/>
                            </ComboBox>
                            <Button Style="{StaticResource ToolbarButton}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Content="Generate Proxies" Margin="0,6,0,0" Command="{Binding GenerateProxiesCommand}"/>
                        </StackPanel>

                        <TextBlock Style="{StaticResource SidebarSectionHeader}" Text="ACTIONS"/>
                        <StackPanel Margin="12,4,12,6">
                            <Button Style="{StaticResource ToolbarButton}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Content="Refresh" Command="{Binding RefreshCommand}"/>
                            <Button Style="{StaticResource ToolbarButton}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Content="Load Metadata" Margin="0,2,0,0" Command="{Binding EnrichAllMetadataCommand}"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" Background="Transparent" HorizontalAlignment="Stretch" Cursor="SizeWE"/>

            <Border Grid.Column="2" Background="{StaticResource AppBackground}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Grid Margin="12,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource BrowserHeader}" Text="{Binding SourcePath}" TextTrimming="CharacterEllipsis" MaxWidth="280" VerticalAlignment="Center"/>
                                <TextBlock Style="{StaticResource StatusText}" Text="{Binding VisibleCountText}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <RadioButton Style="{StaticResource ViewModeButton}" ToolTip="Grid View (Ctrl+1)" GroupName="ViewMode" Command="{Binding SetViewModeCommand}" CommandParameter="Grid" Content="▦" IsChecked="{Binding ViewMode, Converter={StaticResource EnumEquality}, ConverterParameter=Grid}"/>
                                <RadioButton Style="{StaticResource ViewModeButton}" ToolTip="List View (Ctrl+2)" GroupName="ViewMode" Command="{Binding SetViewModeCommand}" CommandParameter="List" Content="☰" IsChecked="{Binding ViewMode, Converter={StaticResource EnumEquality}, ConverterParameter=List}"/>
                                <RadioButton Style="{StaticResource ViewModeButton}" ToolTip="Gallery View (Ctrl+3)" GroupName="ViewMode" Command="{Binding SetViewModeCommand}" CommandParameter="Gallery" Content="◫" IsChecked="{Binding ViewMode, Converter={StaticResource EnumEquality}, ConverterParameter=Gallery}"/>
                                <Separator Style="{StaticResource DarkSeparator}" Margin="6,2"/>
                                <Button Style="{StaticResource IconButton}" ToolTip="Toggle sort direction" Content="↕" Command="{Binding ToggleSortDirectionCommand}"/>
                                <ComboBox x:Name="SortFieldCombo" Style="{StaticResource DarkComboBox}" Width="90" SelectedIndex="0" SelectionChanged="SortFieldCombo_SelectionChanged">
                                    <ComboBoxItem Content="Added"/>
                                    <ComboBoxItem Content="Name"/>
                                    <ComboBoxItem Content="Kind"/>
                                    <ComboBoxItem Content="Modified"/>
                                    <ComboBoxItem Content="Created"/>
                                    <ComboBoxItem Content="Last Opened"/>
                                    <ComboBoxItem Content="Size"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Border Visibility="{Binding ViewMode, Converter={StaticResource ViewModeConv}, ConverterParameter=Grid}" Background="{StaticResource AppBackground}">
                            <ListBox x:Name="GridListBox" ItemsSource="{Binding MediaItems}" SelectedItem="{Binding SelectedItem, Mode=TwoWay}" Style="{StaticResource SidebarList}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel IsItemsHost="True"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="models:MediaItem">
                                        <Border Width="140" Height="148" Margin="4" Background="{StaticResource GridItemBackground}" CornerRadius="4" Cursor="Hand"
                                                ToolTip="{Binding Filename}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Border Grid.Row="0" Margin="4,4,4,0" Background="#151515" CornerRadius="2" ClipToBounds="True">
                                                    <Grid>
                                                        <TextBlock Text="{Binding FileExtension, Converter={StaticResource MediaTypeDisplay}}" Foreground="{StaticResource ForegroundSecondary}" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5"/>
                                                        <Image Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality">
                                                            <Image.Source>
                                                                <MultiBinding Converter="{StaticResource ThumbnailConv}">
                                                                    <Binding Path="Url"/>
                                                                    <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="DataContext"/>
                                                                    <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="DataContext.ThumbnailVersion"/>
                                                                </MultiBinding>
                                                            </Image.Source>
                                                        </Image>
                                                    </Grid>
                                                </Border>

                                                <Grid Grid.Row="1" Margin="4,2,4,4">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="{Binding Filename}" Foreground="{StaticResource ForegroundPrimary}" FontSize="10" TextTrimming="CharacterEllipsis"/>

                                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,2,0,0">
                                                        <TextBlock FontSize="9" Foreground="{StaticResource AccentBrush}" Margin="0,0,4,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="{Binding Rating, StringFormat='★{0}'}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Rating}" Value="0">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock FontSize="9" Foreground="{StaticResource ForegroundSecondary}" Margin="0,0,4,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="{Binding PickState}"/>
                                                                    <Setter Property="Foreground" Value="{StaticResource ForegroundSecondary}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding PickState}" Value="Picked">
                                                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding PickState}" Value="Rejected">
                                                                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding FileSize, Converter={StaticResource FileSize}}" Foreground="{StaticResource ForegroundSecondary}" FontSize="9"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="0" Margin="0">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="Transparent"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="Transparent"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Border>

                        <Border Visibility="{Binding ViewMode, Converter={StaticResource ViewModeConv}, ConverterParameter=List}" Background="{StaticResource AppBackground}">
                            <ListView ItemsSource="{Binding MediaItems}" SelectedItem="{Binding SelectedItem, Mode=TwoWay}" Background="{StaticResource AppBackground}" Foreground="{StaticResource ForegroundPrimary}" BorderThickness="0" FontSize="11">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Name" Width="280" DisplayMemberBinding="{Binding Filename}"/>
                                        <GridViewColumn Header="Kind" Width="70" DisplayMemberBinding="{Binding FileExtension, Converter={StaticResource MediaTypeDisplay}}"/>
                                        <GridViewColumn Header="Rating" Width="60" DisplayMemberBinding="{Binding Rating, StringFormat='{}{0}★'}"/>
                                        <GridViewColumn Header="Size" Width="90" DisplayMemberBinding="{Binding FileSize, Converter={StaticResource FileSize}}"/>
                                        <GridViewColumn Header="Modified" Width="130" DisplayMemberBinding="{Binding ModifiedDate, StringFormat='{}{0:yyyy-MM-dd}'}"/>
                                    </GridView>
                                </ListView.View>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Foreground" Value="{StaticResource ForegroundPrimary}"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="6,3"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource ItemHover}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="{StaticResource ItemSelected}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>
                            </ListView>
                        </Border>

                        <Border Visibility="{Binding ViewMode, Converter={StaticResource ViewModeConv}, ConverterParameter=Gallery}" Background="{StaticResource AppBackground}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="240" MinWidth="180"/>
                                </Grid.ColumnDefinitions>

                                <views:GalleryView Grid.Column="0"/>

                                <GridSplitter Grid.Column="1" Width="4" Background="Transparent" HorizontalAlignment="Stretch" Cursor="SizeWE"/>

                                <Border Grid.Column="2" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <Grid>
                                        <StackPanel Margin="12,10" Visibility="{Binding SelectedItem, Converter={StaticResource NullToVisibility}}">

                                            <TextBlock Style="{StaticResource SidebarSectionHeader}" Text="INFO" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding SelectedItem.Filename}" FontSize="11" Foreground="{StaticResource ForegroundPrimary}" TextWrapping="Wrap" Margin="0,0,0,2"/>
                                            <TextBlock FontSize="9" Foreground="{StaticResource ForegroundSecondary}" Margin="0,0,0,6">
                                                <Run Text="{Binding SelectedItem.FileSize, Converter={StaticResource FileSize}}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding SelectedItem.FileExtension, Converter={StaticResource MediaTypeDisplay}}"/>
                                            </TextBlock>

                                            <TextBlock Style="{StaticResource SidebarSectionHeader}" Text="REVIEW" Margin="0,4,0,4"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <Button FontSize="10" Content="☆" ToolTip="No Rating" Command="{Binding SetRatingCommand}" CommandParameter="0">
                                                    <Button.Style><Style TargetType="Button" BasedOn="{StaticResource IconButton}"/></Button.Style>
                                                </Button>
                                                <Button FontSize="10" ToolTip="Rate 1" Command="{Binding SetRatingCommand}" CommandParameter="1">
                                                    <Button.Style><Style TargetType="Button" BasedOn="{StaticResource IconButton}"><Setter Property="Content" Value="☆"/><Style.Triggers><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="1"><Setter Property="Content" Value="★"/></DataTrigger><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="2"><Setter Property="Content" Value="★"/></DataTrigger><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="3"><Setter Property="Content" Value="★"/></DataTrigger><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="4"><Setter Property="Content" Value="★"/></DataTrigger><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="5"><Setter Property="Content" Value="★"/></DataTrigger></Style.Triggers></Style></Button.Style>
                                                </Button>
                                                <Button FontSize="10" ToolTip="Rate 2" Command="{Binding SetRatingCommand}" CommandParameter="2">
                                                    <Button.Style><Style TargetType="Button" BasedOn="{StaticResource IconButton}"><Setter Property="Content" Value="☆"/><Style.Triggers><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="2"><Setter Property="Content" Value="★"/></DataTrigger><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="3"><Setter Property="Content" Value="★"/></DataTrigger><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="4"><Setter Property="Content" Value="★"/></DataTrigger><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="5"><Setter Property="Content" Value="★"/></DataTrigger></Style.Triggers></Style></Button.Style>
                                                </Button>
                                                <Button FontSize="10" ToolTip="Rate 3" Command="{Binding SetRatingCommand}" CommandParameter="3">
                                                    <Button.Style><Style TargetType="Button" BasedOn="{StaticResource IconButton}"><Setter Property="Content" Value="☆"/><Style.Triggers><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="3"><Setter Property="Content" Value="★"/></DataTrigger><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="4"><Setter Property="Content" Value="★"/></DataTrigger><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="5"><Setter Property="Content" Value="★"/></DataTrigger></Style.Triggers></Style></Button.Style>
                                                </Button>
                                                <Button FontSize="10" ToolTip="Rate 4" Command="{Binding SetRatingCommand}" CommandParameter="4">
                                                    <Button.Style><Style TargetType="Button" BasedOn="{StaticResource IconButton}"><Setter Property="Content" Value="☆"/><Style.Triggers><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="4"><Setter Property="Content" Value="★"/></DataTrigger><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="5"><Setter Property="Content" Value="★"/></DataTrigger></Style.Triggers></Style></Button.Style>
                                                </Button>
                                                <Button FontSize="10" ToolTip="Rate 5" Command="{Binding SetRatingCommand}" CommandParameter="5">
                                                    <Button.Style><Style TargetType="Button" BasedOn="{StaticResource IconButton}"><Setter Property="Content" Value="☆"/><Style.Triggers><DataTrigger Binding="{Binding SelectedItem.Rating}" Value="5"><Setter Property="Content" Value="★"/></DataTrigger></Style.Triggers></Style></Button.Style>
                                                </Button>
                                            </StackPanel>

                                            <TextBlock Text="Pick State" FontSize="10" Foreground="{StaticResource ForegroundSecondary}" Margin="0,2,0,2"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <Button Style="{StaticResource ToolbarButton}" FontSize="10" Content="Unmarked" Width="60" Command="{Binding SetPickStateCommand}" CommandParameter="Unmarked"/>
                                                <Button Style="{StaticResource ToolbarButton}" FontSize="10" Content="Pick" Width="38" Foreground="{StaticResource SuccessBrush}" Command="{Binding SetPickStateCommand}" CommandParameter="Pick"/>
                                                <Button Style="{StaticResource ToolbarButton}" FontSize="10" Content="Reject" Width="44" Foreground="{StaticResource DangerBrush}" Command="{Binding SetPickStateCommand}" CommandParameter="Reject"/>
                                            </StackPanel>

                                            <TextBlock Text="Color Label" FontSize="10" Foreground="{StaticResource ForegroundSecondary}" Margin="0,2,0,2"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <Button Width="18" Height="18" Margin="0,0,2,0" ToolTip="None" Command="{Binding SetColorLabelCommand}" CommandParameter=""><Button.Template><ControlTemplate TargetType="Button"><Border Background="Transparent" CornerRadius="2" BorderBrush="#555" BorderThickness="1"><TextBlock Text="✕" FontSize="8" Foreground="#777" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template></Button>
                                                <Button Width="18" Height="18" Margin="0,0,2,0" ToolTip="Red" Command="{Binding SetColorLabelCommand}" CommandParameter="Red"><Button.Template><ControlTemplate TargetType="Button"><Border Background="#E53935" CornerRadius="2"/></ControlTemplate></Button.Template></Button>
                                                <Button Width="18" Height="18" Margin="0,0,2,0" ToolTip="Yellow" Command="{Binding SetColorLabelCommand}" CommandParameter="Yellow"><Button.Template><ControlTemplate TargetType="Button"><Border Background="#FDD835" CornerRadius="2"/></ControlTemplate></Button.Template></Button>
                                                <Button Width="18" Height="18" Margin="0,0,2,0" ToolTip="Green" Command="{Binding SetColorLabelCommand}" CommandParameter="Green"><Button.Template><ControlTemplate TargetType="Button"><Border Background="#43A047" CornerRadius="2"/></ControlTemplate></Button.Template></Button>
                                                <Button Width="18" Height="18" Margin="0,0,2,0" ToolTip="Blue" Command="{Binding SetColorLabelCommand}" CommandParameter="Blue"><Button.Template><ControlTemplate TargetType="Button"><Border Background="#1E88E5" CornerRadius="2"/></ControlTemplate></Button.Template></Button>
                                                <Button Width="18" Height="18" Margin="0,0,2,0" ToolTip="Purple" Command="{Binding SetColorLabelCommand}" CommandParameter="Purple"><Button.Template><ControlTemplate TargetType="Button"><Border Background="#8E24AA" CornerRadius="2"/></ControlTemplate></Button.Template></Button>
                                            </StackPanel>

                                            <TextBlock Style="{StaticResource SidebarSectionHeader}" Text="METADATA" Margin="0,6,0,4"/>
                                            <TextBlock FontSize="9" Foreground="{StaticResource ForegroundSecondary}" Margin="0,1,0,1"><Run Text="Camera: "/><Run Text="{Binding SelectedItem.CameraModel}" Foreground="{StaticResource ForegroundPrimary}"/></TextBlock>
                                            <TextBlock FontSize="9" Foreground="{StaticResource ForegroundSecondary}" Margin="0,1,0,1"><Run Text="Lens: "/><Run Text="{Binding SelectedItem.LensModel}" Foreground="{StaticResource ForegroundPrimary}"/></TextBlock>
                                            <TextBlock FontSize="9" Foreground="{StaticResource ForegroundSecondary}" Margin="0,1,0,1"><Run Text="ISO "/><Run Text="{Binding SelectedItem.Iso}" Foreground="{StaticResource ForegroundPrimary}"/><Run Text="  f/"/><Run Text="{Binding SelectedItem.Aperture}" Foreground="{StaticResource ForegroundPrimary}"/><Run Text="  "/><Run Text="{Binding SelectedItem.FocalLength, StringFormat='{}{0}mm'}" Foreground="{StaticResource ForegroundPrimary}"/></TextBlock>
                                            <TextBlock FontSize="9" Foreground="{StaticResource ForegroundSecondary}" Margin="0,1,0,1"><Run Text="Shutter: "/><Run Text="{Binding SelectedItem.ShutterSpeed}" Foreground="{StaticResource ForegroundPrimary}"/></TextBlock>
                                            <TextBlock FontSize="9" Foreground="{StaticResource ForegroundSecondary}" Margin="0,1,0,1"><Run Text="Date: "/><Run Text="{Binding SelectedItem.CaptureDate, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Foreground="{StaticResource ForegroundPrimary}"/></TextBlock>
                                            <TextBlock FontSize="9" Foreground="{StaticResource ForegroundSecondary}" Margin="0,1,0,1"><Run Text="Dimensions: "/><Run Text="{Binding SelectedItem.PixelWidth}" Foreground="{StaticResource ForegroundPrimary}"/><Run Text=" × "/><Run Text="{Binding SelectedItem.PixelHeight}" Foreground="{StaticResource ForegroundPrimary}"/></TextBlock>
                                            <TextBlock FontSize="9" Foreground="{StaticResource ForegroundSecondary}" Margin="0,1,0,1" Visibility="{Binding SelectedItem.ColorSpaceName, Converter={StaticResource NullToVisibility}}"><Run Text="Color: "/><Run Text="{Binding SelectedItem.ColorSpaceName}" Foreground="{StaticResource ForegroundPrimary}"/></TextBlock>
                                            <TextBlock FontSize="9" Foreground="{StaticResource ForegroundSecondary}" Margin="0,4,0,0"><Run Text="XMP: "/><Run Text="{Binding SelectedItem.XmpStatus}"/></TextBlock>

                                            <StackPanel Margin="0,10,0,0" Visibility="{Binding HistogramPlacement, Converter={StaticResource EnumEquality}, ConverterParameter=Inspector}">
                                                <DockPanel Margin="0,0,0,4">
                                                    <TextBlock Style="{StaticResource SidebarSectionHeader}" Text="HISTOGRAM" Margin="0"/>
                                                    <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}" Content="↗" Width="22" Height="18" ToolTip="Move to floating" Command="{Binding SetHistogramPlacementCommand}" CommandParameter="Floating"/>
                                                </DockPanel>
                                                <Border Height="108" Background="#CC1E1E1E" CornerRadius="3" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                                    <controls:HistogramView Data="{Binding HistogramChannel}" DisplayMode="{Binding HistogramMode}"/>
                                                </Border>
                                            </StackPanel>

                                            <StackPanel Margin="0,10,0,0" Visibility="{Binding WaveformPlacement, Converter={StaticResource EnumEquality}, ConverterParameter=Inspector}">
                                                <DockPanel Margin="0,0,0,4">
                                                    <TextBlock Style="{StaticResource SidebarSectionHeader}" Text="WAVEFORM" Margin="0"/>
                                                    <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}" Content="↗" Width="22" Height="18" ToolTip="Move to floating" Command="{Binding SetWaveformPlacementCommand}" CommandParameter="Floating"/>
                                                </DockPanel>
                                                <Border Height="124" Background="#CC1E1E1E" CornerRadius="3" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                                    <controls:WaveformView Waveform="{Binding WaveformData}" MaxValue="{Binding WaveformMaxValue}" ChannelMode="{Binding WaveformChannelMode}"/>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Margin="12,10" Visibility="{Binding SelectedItem, Converter={StaticResource NullToVisibility}, ConverterParameter=Invert}">
                                            <TextBlock Text="Select media to edit rating, label, and copy state." FontSize="11" Foreground="{StaticResource ForegroundSecondary}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        </Grid>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Background="{StaticResource AppBackground}" Visibility="{Binding HasItems, Converter={StaticResource InverseBool}}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Select a source folder to browse"/>
                                            <Setter Property="Foreground" Value="{StaticResource ForegroundSecondary}"/>
                                            <Setter Property="FontSize" Value="14"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                                    <Setter Property="Text" Value="Scanning folder..."/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Button Style="{StaticResource ToolbarButton}" Content="Choose Folder..." Command="{Binding SelectSourceFolderCommand}" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="22"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Visibility="{Binding IsCopyRunning, Converter={StaticResource BoolToVisibility}}" Background="{StaticResource ToolbarBackground}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid Margin="12,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock FontSize="10" Foreground="{StaticResource ForegroundPrimary}" Text="{Binding CopyStatusText}"/>
                        <ProgressBar Style="{StaticResource DarkProgressBar}" Margin="0,3,0,0" Value="{Binding CopyFraction}" Maximum="1" Minimum="0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <Button Style="{StaticResource ToolbarButton}" FontSize="10" Content="Pause" Width="46" Command="{Binding PauseCopyCommand}"/>
                        <Button Style="{StaticResource ToolbarButton}" FontSize="10" Content="Resume" Width="50" Command="{Binding ResumeCopyCommand}"/>
                        <Button Style="{StaticResource ToolbarButton}" FontSize="10" Content="Cancel" Width="46" Foreground="{StaticResource DangerBrush}" Command="{Binding CancelCopyCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <views:CopyLogView Grid.Row="0" Visibility="{Binding ShowCopyLog, Converter={StaticResource BoolToVisibility}}"/>

            <Border Grid.Row="1" Background="{StaticResource ToolbarBackground}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding StatusText}" Style="{StaticResource StatusText}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding SelectedCountText}" Foreground="{StaticResource ForegroundSecondary}" FontSize="11" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
